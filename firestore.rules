// firestore.rules
// Regras de PRODUÇÃO — deny by default: toda collection sem regra explícita é bloqueada
// (ver o "catch-all" no final do arquivo).
//
// Como aplicar (só quando estiver pronto pra testar — ver instruções completas no chat):
//   1) Console: Firebase Console → Firestore Database → Regras → colar este arquivo → Publicar
//   2) CLI: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────────────────── Helpers ─────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Uid da conta admin, hardcoded de propósito: Rules não importa
    // src/config/admin.ts, então este valor precisa ser mantido em sincronia
    // manual com ADMIN_UID no app (e com os literais iguais já usados na
    // regra de create de matches/{matchId} e no allow read de verifications).
    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'Gd0pJi8WjYS60JHOnhIx9R6vktJ3';
    }

    // Evita repetir o texto do get() de matches/{matchId} nas regras abaixo.
    function getMatch(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data;
    }

    // Evita repetir o texto do get() de support/{ticketId} nas regras da
    // subcollection support/{ticketId}/messages (S38).
    function getTicket(ticketId) {
      return get(/databases/$(database)/documents/support/$(ticketId)).data;
    }

    // Recebe o match já lido (getMatch chamado 1x pelo caller) em vez de
    // chamar getMatch de novo aqui — Rules não tem 'let', então isso é o jeito
    // de checar duas condições sobre o mesmo doc com um único get() faturado.
    function matchAllowsPost(m, uid) {
      return uid in m.users && m.get('blockedBy', []).size() == 0;
    }

    // Um item de users/{uid}.prompts[] — { id: string, answer: string },
    // resposta de 1 a 150 chars. Ver src/constants/prompts.ts (catálogo) e
    // MAX_ANSWER_LENGTH no app.
    function isValidPromptItem(item) {
      return item is map && item.keys().hasOnly(['id', 'answer'])
        && item.id is string
        && item.answer is string && item.answer.size() >= 1 && item.answer.size() <= 150
        && item.answer.matches('.*\\S.*');
    }

    // Rules não tem loop — valida cada item individualmente por índice, com
    // curto-circuito no size() (padrão igual ao comentário do S33: só entra
    // no índice N se list.size() > N). Máximo 3 prompts (MAX_PROMPTS no app).
    // Cada ramo também barra id duplicado contra os índices já validados
    // antes dele (list[1] vs list[0]; list[2] vs list[0] e list[1]).
    function isValidPrompts(list) {
      return list is list && list.size() <= 3
        && (list.size() == 0
            || (isValidPromptItem(list[0])
                && (list.size() == 1
                    || (isValidPromptItem(list[1])
                        && list[0].id != list[1].id
                        && (list.size() == 2
                            || (isValidPromptItem(list[2])
                                && list[0].id != list[2].id
                                && list[1].id != list[2].id))))));
    }

    // Campos que o dono do perfil pode criar/editar. Qualquer campo fora desta
    // lista (ex: um futuro "isAdmin" ou "verified") NUNCA pode ser escrito pelo
    // client, mesmo que alguém adicione o campo no app no futuro e esqueça de
    // atualizar as regras — hasOnly() bloqueia por padrão.
    function isValidProfile(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 60
        && data.age is number && data.age >= 18 && data.age <= 100
        && data.bio is string && data.bio.size() <= 500
        && data.photoURL is string
        && data.photos is list && data.photos.size() <= 6
        && data.interests is list && data.interests.size() <= 15
        && (!('gender' in data) || data.gender in ['masculino', 'feminino', 'outro'])
        && (!('location' in data) || (data.location.lat is number && data.location.lng is number))
        && (!('filters' in data) || data.filters is map)
        && (!('prompts' in data) || isValidPrompts(data.prompts));
    }

    // Um match só pode ser criado se as DUAS pessoas já deram like/superlike uma
    // na outra. Recalcula a condição no servidor via get() — nunca confia no
    // client dizer "isMatch: true", porque o client pode mentir.
    function mutualLikeExists(users) {
      return exists(/databases/$(database)/documents/swipes/$(users[0] + '_' + users[1]))
        && exists(/databases/$(database)/documents/swipes/$(users[1] + '_' + users[0]))
        && get(/databases/$(database)/documents/swipes/$(users[0] + '_' + users[1])).data.direction != 'nope'
        && get(/databases/$(database)/documents/swipes/$(users[1] + '_' + users[0])).data.direction != 'nope';
    }

    // ───────────────────────── users ─────────────────────────
    //
    // O token de push mora em users/{uid}/private/push (ver subregra abaixo),
    // não mais em users/{uid}.pushToken — Firestore Rules não faz redação por
    // campo em leitura, então qualquer campo no doc principal fica visível a
    // todo usuário autenticado (allow read abaixo é intencionalmente amplo,
    // para permitir o Swipe/Discover). O envio de push é feito por Cloud
    // Function (Admin SDK, ignora estas regras) — ver functions/src/index.ts.
    match /users/{userId} {
      allow read: if isSignedIn();

      // lookingFor fica FORA de isValidProfile() de propósito, igual uid/
      // createdAt acima: create e update têm exigência diferente pra ele (o
      // único campo obrigatório da lista, os demais são todos opcionais
      // dentro de isValidProfile), então cada allow valida do seu jeito em
      // vez de a função compartilhada ganhar um parâmetro pra isso.
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.createdAt == request.time
        // Obrigatório no cadastro: sem o campo (ou com valor fora da
        // lista), o create inteiro é negado.
        && request.resource.data.lookingFor in
             ['relacionamento_serio', 'casual', 'amizade', 'descobrindo']
        // S44 — mesmo padrão de lookingFor acima: descoberta nacional depende
        // de toda conta nova ter uf, então é obrigatório no cadastro. Sem o
        // campo (ou com sigla fora da lista), o create inteiro é negado.
        && request.resource.data.uf in
             ['AC', 'AL', 'AM', 'AP', 'BA', 'CE', 'DF', 'ES', 'GO', 'MA', 'MG',
              'MS', 'MT', 'PA', 'PB', 'PE', 'PI', 'PR', 'RJ', 'RN', 'RO', 'RR',
              'RS', 'SC', 'SE', 'SP', 'TO']
        && request.resource.data.keys().hasOnly(
             ['uid', 'name', 'age', 'bio', 'photoURL', 'photos', 'interests',
              'gender', 'lookingFor', 'uf', 'location', 'filters', 'createdAt', 'prompts'])
        && isValidProfile(request.resource.data);

      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        // Versão estrita: compara presença ANTES (resource.data) e DEPOIS
        // (request.resource.data), não só o resultado isolado. Dois ramos:
        // (a) ausente nos dois — conta de teste sem o campo continua
        //     editando bio/foto/etc. sem travar; (b) presente no resultado
        //     e com valor válido — cobre tanto "já tinha e trocou entre as
        //     4 opções" quanto "não tinha e está definindo pela 1ª vez fora
        //     do cadastro". Fora desses dois ramos só sobra o caso "tinha
        //     antes e sumiu no resultado" — nenhum dos dois ramos cobre
        //     isso, então fica negado: não dá pra remover o campo depois de
        //     setado.
        && ((!('lookingFor' in resource.data) && !('lookingFor' in request.resource.data))
            || ('lookingFor' in request.resource.data && request.resource.data.lookingFor in
                  ['relacionamento_serio', 'casual', 'amizade', 'descobrindo']))
        // S44 — mesmo padrão do ramo de lookingFor acima, aplicado a uf: (a)
        // ausente nos dois — conta legada sem uf segue editando bio/foto/etc.
        // sem travar; (b) presente no resultado e com sigla válida — cobre
        // tanto "já tinha e trocou entre as 27" quanto "não tinha e está
        // definindo pela 1ª vez fora do cadastro". O caso "tinha antes e
        // sumiu no resultado" não cai em nenhum dos dois ramos, então fica
        // negado — não dá pra remover uf depois de setado.
        && ((!('uf' in resource.data) && !('uf' in request.resource.data))
            || ('uf' in request.resource.data && request.resource.data.uf in
                  ['AC', 'AL', 'AM', 'AP', 'BA', 'CE', 'DF', 'ES', 'GO', 'MA', 'MG',
                   'MS', 'MT', 'PA', 'PB', 'PE', 'PI', 'PR', 'RJ', 'RN', 'RO', 'RR',
                   'RS', 'SC', 'SE', 'SP', 'TO']))
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['name', 'age', 'bio', 'photoURL', 'photos', 'interests',
              'gender', 'lookingFor', 'uf', 'location', 'filters', 'prompts', 'lastActiveAt',
              'reengagementOptOut'])
        // lastActiveAt só entra via serverTimestamp() do client — se a chave
        // foi tocada nesta escrita, o valor tem que ser o horário do próprio
        // servidor, nunca um timestamp arbitrário mandado pelo client.
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastActiveAt'])
            || request.resource.data.lastActiveAt == request.time)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['reengagementOptOut'])
            || request.resource.data.reengagementOptOut is bool)
        && isValidProfile(request.resource.data);

      allow delete: if isOwner(userId);

      // ─────────────── users/{userId}/private ───────────────
      // Dois documentos com regras próprias (não um wildcard único), porque
      // têm mutabilidade diferente: o push token é regravado a cada refresh,
      // o ChaveF do cadastro (S-ChaveF) é criado uma vez e nunca muda.

      // users/{userId}/private/push — token do Expo push, só o dono lê/escreve.
      match /private/push {
        allow read, write: if isOwner(userId);
      }

      // users/{userId}/private/registration — ChaveF capturado no cadastro.
      // Nunca exposto no doc público users/{userId} (que tem read amplo pra
      // qualquer autenticado, por causa do Swipe/Discover) — só o dono e o
      // admin enxergam. Imutável: uma vez criado, nem o dono pode alterar
      // (allow update, delete: if false, explícito, não só ausência de regra).
      match /private/registration {
        allow read: if isOwner(userId) || isAdmin();

        allow create: if isOwner(userId)
          && request.resource.data.chaveF is string
          && request.resource.data.chaveF.matches('^F\\d{7}$')
          && request.resource.data.createdAt == request.time
          && request.resource.data.keys().hasOnly(['chaveF', 'createdAt']);

        allow update, delete: if false;
      }
    }

    // ───────────────────────── users/{uid}/superLikes/usage (Super Like Fase 2) ─────────────────────────
    //
    // Contador mensal de superlikes, em caminho absoluto (em vez de aninhado
    // em match /users/{userId} acima) pra não colidir o nome da variável de
    // path com o {userId} já usado ali. year/month são sempre UTC (bate com
    // request.time.year()/month(), que o servidor calcula em UTC) e o count
    // só pode subir de 1 em 1 dentro do mesmo mês, ou resetar pra 1 num mês
    // novo — nunca decrementar nem pular direto pra um valor maior.
    match /users/{uid}/superLikes/usage {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['year', 'month', 'count'])
        && request.resource.data.year == request.time.year()
        && request.resource.data.month == request.time.month()
        && request.resource.data.count == 1;
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['year', 'month', 'count'])
        && request.resource.data.year == request.time.year()
        && request.resource.data.month == request.time.month()
        && (
          (resource.data.year == request.time.year()
            && resource.data.month == request.time.month()
            && request.resource.data.count == resource.data.count + 1
            && request.resource.data.count <= 3)
          ||
          ((resource.data.year != request.time.year()
            || resource.data.month != request.time.month())
            && request.resource.data.count == 1)
        );
      allow delete: if false;
    }

    // ───────────────────────── swipes ─────────────────────────
    //
    // Leitura liberada para from==me OU to==me (decisão consciente: a tela
    // "Quem curtiu você" depende de ler swipes onde to==me, antes do match).
    // Ninguém lê swipes de terceiros nem consegue "vasculhar" quem curtiu quem.
    match /swipes/{swipeId} {
      allow read: if isSignedIn()
        && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.to != request.auth.uid
        && swipeId == request.resource.data.from + '_' + request.resource.data.to
        && request.resource.data.direction in ['like', 'nope', 'superlike']
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(['from', 'to', 'direction', 'createdAt', 'likedPhotoURL', 'context'])
        // S35: contexto opcional ("curtiu sua foto") — só existe em
        // like/superlike (nope nunca leva contexto pro alvo); campo
        // ausente continua válido (compat com nope e clients antigos).
        && (
          !('likedPhotoURL' in request.resource.data)
          || (
            request.resource.data.direction != 'nope'
            && request.resource.data.likedPhotoURL is string
            && request.resource.data.likedPhotoURL.size() > 0
            && request.resource.data.likedPhotoURL.size() <= 2048
          )
        )
        // S35-A: mesmo padrão do likedPhotoURL acima, mas como REFERÊNCIA
        // (nunca URL/texto) do que estava visível no card — índice de foto
        // ou id de prompt. Coexiste com likedPhotoURL (client ainda grava os
        // dois); consolidar os dois campos fica pra uma etapa futura.
        && (
          !('context' in request.resource.data)
          || (
            request.resource.data.direction != 'nope'
            && request.resource.data.context is map
            && request.resource.data.context.keys().size() == 2
            && (
              (
                request.resource.data.context.type == 'photo'
                && request.resource.data.context.photoIndex is int
                && request.resource.data.context.photoIndex >= 0
                && request.resource.data.context.photoIndex < 9
              )
              || (
                request.resource.data.context.type == 'prompt'
                && request.resource.data.context.promptId is string
                && request.resource.data.context.promptId.size() > 0
                && request.resource.data.context.promptId.size() < 60
              )
            )
          )
        )
        // Super Like Fase 2: se o swipe é 'superlike', o contador mensal
        // (users/{uid}/superLikes/usage) precisa ter sido escrito no MESMO
        // batch com um incremento real (getAfter reflete a escrita do batch
        // ainda não commitado) — sem isso, um client malicioso criaria o
        // swipe sem gastar cota. As próprias rules do contador acima já
        // impedem resetar/decrementar count dentro do mesmo mês.
        && (
          request.resource.data.direction != 'superlike'
          || (
            getAfter(/databases/$(database)/documents/users/$(request.auth.uid)/superLikes/usage).data.year == request.time.year()
            && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)/superLikes/usage).data.month == request.time.month()
            && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)/superLikes/usage).data.count <= 3
            && (
              !exists(/databases/$(database)/documents/users/$(request.auth.uid)/superLikes/usage)
                ? getAfter(/databases/$(database)/documents/users/$(request.auth.uid)/superLikes/usage).data.count == 1
                : (
                  (get(/databases/$(database)/documents/users/$(request.auth.uid)/superLikes/usage).data.year == request.time.year()
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)/superLikes/usage).data.month == request.time.month())
                    ? getAfter(/databases/$(database)/documents/users/$(request.auth.uid)/superLikes/usage).data.count == get(/databases/$(database)/documents/users/$(request.auth.uid)/superLikes/usage).data.count + 1
                    : getAfter(/databases/$(database)/documents/users/$(request.auth.uid)/superLikes/usage).data.count == 1
                )
            )
          )
        );

      allow update: if false; // swipe é imutável — nunca se reescreve, só se cria/apaga

      allow delete: if isSignedIn() && resource.data.from == request.auth.uid; // usado por undoSwipe()
    }

    // ───────────────────────── matches ─────────────────────────
    match /matches/{matchId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;

      // Uid da conta admin, hardcoded de propósito: Rules não importa
      // src/config/admin.ts, então este valor precisa ser mantido em sincronia
      // manual com ADMIN_UID no app. Ninguém dá match com o admin, nem via API.
      allow create: if isSignedIn()
        && request.resource.data.users is list
        && request.resource.data.users.size() == 2
        && request.resource.data.users[0] != request.resource.data.users[1]
        && request.auth.uid in request.resource.data.users
        && !('Gd0pJi8WjYS60JHOnhIx9R6vktJ3' in request.resource.data.users)
        && (matchId == request.resource.data.users[0] + '_' + request.resource.data.users[1]
            || matchId == request.resource.data.users[1] + '_' + request.resource.data.users[0])
        && mutualLikeExists(request.resource.data.users)
        && request.resource.data.createdAt == request.time
        && (!('typing' in request.resource.data) || request.resource.data.typing == {})
        // blockedBy (S19) e lastMessage (S27) são de propósito ausentes desta
        // lista: só Cloud Functions (Admin SDK — onBlockCreated/onBlockDeleted
        // e onMessageCreated respectivamente) podem escrevê-los. Admin SDK
        // bypassa rules, então isso não impede as functions, só o client.
        && request.resource.data.keys().hasOnly(['users', 'createdAt', 'typing']);

      // Ninguém pode trocar os participantes depois de criado. lastMessage
      // NUNCA aparece aqui — é escrito só pela Cloud Function onMessageCreated
      // via Admin SDK (bypassa rules), o client não tem allow para ele. Do que
      // o client pode mudar: typing (cada um só altera a própria chave — não
      // dá pra forjar "a outra pessoa está digitando") e lastReadAt (S27,
      // idem: cada um só marca a própria leitura, nunca a do outro).
      allow update: if isSignedIn() && request.auth.uid in resource.data.users
        && request.resource.data.users == resource.data.users
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['typing', 'lastReadAt'])
        && resource.data.get('typing', {}).diff(request.resource.data.get('typing', {}))
             .affectedKeys().hasOnly([request.auth.uid])
        && resource.data.get('lastReadAt', {}).diff(request.resource.data.get('lastReadAt', {}))
             .affectedKeys().hasOnly([request.auth.uid])
        && (resource.data.get('lastReadAt', {}).diff(request.resource.data.get('lastReadAt', {}))
              .affectedKeys().size() == 0
            || request.resource.data.lastReadAt[request.auth.uid] is timestamp);

      // Decisão: qualquer participante pode apagar o match a qualquer momento
      // (usado hoje só por undoSwipe(), mas também funciona como "desfazer
      // match"/unmatch geral). Débito técnico: mensagens da subcoleção ficam
      // órfãs (inacessíveis, mas não deletadas) — limpeza real exigiria uma
      // Cloud Function.
      allow delete: if isSignedIn() && request.auth.uid in resource.data.users;

      // ─────────────── matches/{matchId}/messages ───────────────
      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in getMatch(matchId).users;

        // blockedBy vazio/ausente (S19) é exigido no create: enquanto alguém
        // tiver o match bloqueado, ninguém — nem quem bloqueou, nem quem foi
        // bloqueado — consegue mandar mensagem, mesmo direto pela API.
        allow create: if isSignedIn()
          && matchAllowsPost(getMatch(matchId), request.auth.uid)
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('verified', false) == true
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000
          && request.resource.data.createdAt == request.time
          && (!('imageUrl' in request.resource.data) || request.resource.data.imageUrl is string)
          && (!('location' in request.resource.data) ||
              (request.resource.data.location.latitude is number
               && request.resource.data.location.longitude is number))
          // mensagem precisa ter algum conteúdo: texto OU foto OU localização
          && (request.resource.data.text.size() > 0
              || 'imageUrl' in request.resource.data
              || 'location' in request.resource.data)
          && request.resource.data.keys().hasOnly(['text', 'senderId', 'createdAt', 'imageUrl', 'location']);

        // O app não tem função de editar/apagar mensagem hoje — deny by
        // default. Se um dia existir "apagar minha mensagem", trocar por:
        // allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ───────────────────────── blocks (S19) ─────────────────────────
    //
    // O client só cria/apaga o doc de bloqueio — nunca escreve users/{uid}.blockedUsers
    // diretamente (ver abaixo). Quem propaga o array pros dois lados e desfaz o
    // match é a Cloud Function onBlockCreated/onBlockDeleted (Admin SDK, ignora
    // estas regras) — ver functions/src/index.ts.
    //
    // Leitura restrita a quem bloqueou (ninguém lê "quem me bloqueou" por aqui —
    // essa informação só existe agregada, e sem direção, no array blockedUsers
    // de cada perfil, que já é público por causa do Descobrir/Swipe).
    match /blocks/{blockId} {
      allow read: if isSignedIn() && resource.data.blocker == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.blocker == request.auth.uid
        && request.resource.data.blocked is string
        && request.resource.data.blocked != request.auth.uid
        && blockId == request.resource.data.blocker + '_' + request.resource.data.blocked
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(['blocker', 'blocked', 'createdAt']);

      allow update: if false; // bloqueio é imutável — só se cria/apaga

      allow delete: if isSignedIn() && resource.data.blocker == request.auth.uid; // usado por unblockUser()
    }

    // ───────────────────────── reports (S19) ─────────────────────────
    //
    // Denúncia é só de ida: ninguém lê, edita ou apaga uma denúncia pelo client
    // (nem quem denunciou, nem quem foi denunciado) — revisão é manual, via
    // Console/Cloud Function futura.
    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.reportedId is string
        && request.resource.data.reportedId != request.auth.uid
        && request.resource.data.reason in
             ['spam', 'offensive_content', 'fake_profile', 'inappropriate_behavior', 'other']
        && request.resource.data.details is string && request.resource.data.details.size() <= 500
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(
             ['reporterId', 'reportedId', 'reason', 'details', 'createdAt']);

      allow read, update, delete: if false;
    }

    // ───────────────────────── verifications (S20) ─────────────────────────
    //
    // Pedido de verificação de perfil (selfie). Doc id == uid do usuário — 1
    // pedido por pessoa, reenviar sobrescreve o documento inteiro (por isso o
    // client precisa usar setDoc sem merge: um updateDoc parcial deixaria
    // reviewedAt/reviewedBy antigos no doc e o hasOnly() do dono abaixo
    // rejeitaria o reenvio).
    //
    // Uid do admin hardcoded de propósito (mesmo valor de ADMIN_UID em
    // src/config/admin.ts e do literal já usado na regra de create de
    // matches/{matchId} acima — Rules não importa constantes do app, então
    // os três precisam ficar em sincronia manual). A Cloud Function
    // onVerificationReviewed (Admin SDK, ignora estas regras) é quem
    // sincroniza users/{uid}.verified a partir da mudança de status aqui —
    // ver functions/src/index.ts.
    match /verifications/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // Dono cria/reenvia: só como 'pending', com selfieUrl e createdAt —
      // nunca consegue setar status já aprovado/rejeitado nem escrever
      // reviewedAt/reviewedBy (hasOnly bloqueia por padrão).
      allow create, update: if isOwner(uid)
        && request.resource.data.status == 'pending'
        && request.resource.data.selfieUrl is string
        && request.resource.data.selfieUrl.size() > 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(['status', 'selfieUrl', 'createdAt']);

      // Admin revisa: só pode mexer em status/reviewedAt/reviewedBy, e só pra
      // aprovar ou rejeitar — nunca reescreve selfieUrl/createdAt do usuário,
      // então não dá pra forjar uma aprovação por essa via nem pela do dono.
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'reviewedAt', 'reviewedBy'])
        && request.resource.data.status in ['approved', 'rejected']
        && request.resource.data.reviewedAt == request.time
        && request.resource.data.reviewedBy == request.auth.uid;

      allow delete: if false;
    }

    // ───────────────────────── support (S36-S40) ─────────────────────────
    //
    // Ticket de Ajuda/Fale Conosco. Ao contrário de reports (só de ida), o
    // dono pode ler o próprio ticket. status começa sempre 'open' no create
    // (client nunca cria já 'resolved'). lastMessageAt (S40) é escrito só
    // pela Cloud Function onSupportMessageCreated (Admin SDK, bypassa estas
    // regras) — o client não tem allow para esse campo, nem em create nem
    // em update.
    match /support/{ticketId} {
      allow read: if isAdmin() || resource.data.uid == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.category in
             ['duvida', 'problema_tecnico', 'denuncia', 'sugestao', 'conta']
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 1000
        && request.resource.data.message.matches('.*\\S.*')
        && request.resource.data.status == 'open'
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(
             ['uid', 'category', 'message', 'status', 'createdAt']);

      // S38: dono ganhou permissão de update, mas só no campo status, e só
      // pra REABRIR o próprio ticket (resolved -> open, nunca o contrário) —
      // o hasOnly(affectedKeys) abaixo já garante que uid/category/message/
      // createdAt/lastMessageAt do usuário nunca são reescritos por essa
      // via. Admin continua podendo ir pra qualquer direção
      // (open<->resolved), igual reviewVerification em
      // verificationService.ts.
      allow update: if isSignedIn()
        && (isAdmin() || isOwner(resource.data.uid))
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status'])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
          || (
            request.resource.data.status in ['open', 'resolved']
            && (
              isAdmin()
              || (resource.data.status == 'resolved' && request.resource.data.status == 'open')
            )
          )
        );

      allow delete: if false;

      // ─────────────── support/{ticketId}/messages (S38) ───────────────
      //
      // Mensagens da thread — mesmo padrão de imutabilidade de
      // matches/{matchId}/messages (update/delete: false). senderId é
      // sempre o uid de quem escreveu de verdade, inclusive quando é o
      // admin respondendo — "Equipe JuntaVale" é só rótulo de UI (S39), não
      // existe como dado aqui.
      match /messages/{messageId} {
        allow read: if isAdmin() || (isSignedIn() && getTicket(ticketId).uid == request.auth.uid);

        // getAfter() em vez de getTicket() aqui: no writeBatch de
        // submitSupportTicket, o ticket pai e esta 1ª mensagem nascem no
        // mesmo batch, e get() só enxerga o estado PRÉ-batch (doc pai ainda
        // não existe) — mesmo padrão já usado no getAfter() da quota de
        // superlike em swipes/{swipeId}.
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && (isAdmin()
              || getAfter(/databases/$(database)/documents/support/$(ticketId)).data.uid
                   == request.auth.uid)
          && request.resource.data.text is string
          && request.resource.data.text.size() >= 1
          && request.resource.data.text.size() <= 1000
          && request.resource.data.text.matches('.*\\S.*')
          && request.resource.data.createdAt == request.time
          && request.resource.data.keys().hasOnly(['senderId', 'text', 'createdAt']);

        allow update, delete: if false;
      }
    }

    // ───────────────────────── deny by default ─────────────────────────
    // Qualquer collection não listada acima (inclusive erros de digitação no
    // nome de uma collection) é bloqueada por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
