// firestore.rules
// Regras de PRODUÇÃO — deny by default: toda collection sem regra explícita é bloqueada
// (ver o "catch-all" no final do arquivo).
//
// Como aplicar (só quando estiver pronto pra testar — ver instruções completas no chat):
//   1) Console: Firebase Console → Firestore Database → Regras → colar este arquivo → Publicar
//   2) CLI: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────────────────── Helpers ─────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Uid da conta admin, hardcoded de propósito: Rules não importa
    // src/config/admin.ts, então este valor precisa ser mantido em sincronia
    // manual com ADMIN_UID no app (e com os literais iguais já usados na
    // regra de create de matches/{matchId} e no allow read de verifications).
    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'Gd0pJi8WjYS60JHOnhIx9R6vktJ3';
    }

    // Evita repetir o texto do get() de matches/{matchId} nas regras abaixo.
    function getMatch(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data;
    }

    // Recebe o match já lido (getMatch chamado 1x pelo caller) em vez de
    // chamar getMatch de novo aqui — Rules não tem 'let', então isso é o jeito
    // de checar duas condições sobre o mesmo doc com um único get() faturado.
    function matchAllowsPost(m, uid) {
      return uid in m.users && m.get('blockedBy', []).size() == 0;
    }

    // Campos que o dono do perfil pode criar/editar. Qualquer campo fora desta
    // lista (ex: um futuro "isAdmin" ou "verified") NUNCA pode ser escrito pelo
    // client, mesmo que alguém adicione o campo no app no futuro e esqueça de
    // atualizar as regras — hasOnly() bloqueia por padrão.
    function isValidProfile(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 60
        && data.age is number && data.age >= 18 && data.age <= 100
        && data.bio is string && data.bio.size() <= 500
        && data.photoURL is string
        && data.photos is list && data.photos.size() <= 6
        && data.interests is list && data.interests.size() <= 15
        && (!('gender' in data) || data.gender in ['masculino', 'feminino', 'outro'])
        && (!('location' in data) || (data.location.lat is number && data.location.lng is number))
        && (!('filters' in data) || data.filters is map);
    }

    // Um match só pode ser criado se as DUAS pessoas já deram like/superlike uma
    // na outra. Recalcula a condição no servidor via get() — nunca confia no
    // client dizer "isMatch: true", porque o client pode mentir.
    function mutualLikeExists(users) {
      return exists(/databases/$(database)/documents/swipes/$(users[0] + '_' + users[1]))
        && exists(/databases/$(database)/documents/swipes/$(users[1] + '_' + users[0]))
        && get(/databases/$(database)/documents/swipes/$(users[0] + '_' + users[1])).data.direction != 'nope'
        && get(/databases/$(database)/documents/swipes/$(users[1] + '_' + users[0])).data.direction != 'nope';
    }

    // ───────────────────────── users ─────────────────────────
    //
    // O token de push mora em users/{uid}/private/push (ver subregra abaixo),
    // não mais em users/{uid}.pushToken — Firestore Rules não faz redação por
    // campo em leitura, então qualquer campo no doc principal fica visível a
    // todo usuário autenticado (allow read abaixo é intencionalmente amplo,
    // para permitir o Swipe/Discover). O envio de push é feito por Cloud
    // Function (Admin SDK, ignora estas regras) — ver functions/src/index.ts.
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(
             ['uid', 'name', 'age', 'bio', 'photoURL', 'photos', 'interests',
              'gender', 'location', 'filters', 'createdAt'])
        && isValidProfile(request.resource.data);

      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['name', 'age', 'bio', 'photoURL', 'photos', 'interests',
              'gender', 'location', 'filters'])
        && isValidProfile(request.resource.data);

      allow delete: if isOwner(userId);

      // ─────────────── users/{userId}/private ───────────────
      // Dois documentos com regras próprias (não um wildcard único), porque
      // têm mutabilidade diferente: o push token é regravado a cada refresh,
      // o ChaveF do cadastro (S-ChaveF) é criado uma vez e nunca muda.

      // users/{userId}/private/push — token do Expo push, só o dono lê/escreve.
      match /private/push {
        allow read, write: if isOwner(userId);
      }

      // users/{userId}/private/registration — ChaveF capturado no cadastro.
      // Nunca exposto no doc público users/{userId} (que tem read amplo pra
      // qualquer autenticado, por causa do Swipe/Discover) — só o dono e o
      // admin enxergam. Imutável: uma vez criado, nem o dono pode alterar
      // (allow update, delete: if false, explícito, não só ausência de regra).
      match /private/registration {
        allow read: if isOwner(userId) || isAdmin();

        allow create: if isOwner(userId)
          && request.resource.data.chaveF is string
          && request.resource.data.chaveF.matches('^F\\d{7}$')
          && request.resource.data.createdAt == request.time
          && request.resource.data.keys().hasOnly(['chaveF', 'createdAt']);

        allow update, delete: if false;
      }
    }

    // ───────────────────────── swipes ─────────────────────────
    //
    // Leitura liberada para from==me OU to==me (decisão consciente: a tela
    // "Quem curtiu você" depende de ler swipes onde to==me, antes do match).
    // Ninguém lê swipes de terceiros nem consegue "vasculhar" quem curtiu quem.
    match /swipes/{swipeId} {
      allow read: if isSignedIn()
        && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.to != request.auth.uid
        && swipeId == request.resource.data.from + '_' + request.resource.data.to
        && request.resource.data.direction in ['like', 'nope', 'superlike']
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(['from', 'to', 'direction', 'createdAt']);

      allow update: if false; // swipe é imutável — nunca se reescreve, só se cria/apaga

      allow delete: if isSignedIn() && resource.data.from == request.auth.uid; // usado por undoSwipe()
    }

    // ───────────────────────── matches ─────────────────────────
    match /matches/{matchId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;

      // Uid da conta admin, hardcoded de propósito: Rules não importa
      // src/config/admin.ts, então este valor precisa ser mantido em sincronia
      // manual com ADMIN_UID no app. Ninguém dá match com o admin, nem via API.
      allow create: if isSignedIn()
        && request.resource.data.users is list
        && request.resource.data.users.size() == 2
        && request.resource.data.users[0] != request.resource.data.users[1]
        && request.auth.uid in request.resource.data.users
        && !('Gd0pJi8WjYS60JHOnhIx9R6vktJ3' in request.resource.data.users)
        && (matchId == request.resource.data.users[0] + '_' + request.resource.data.users[1]
            || matchId == request.resource.data.users[1] + '_' + request.resource.data.users[0])
        && mutualLikeExists(request.resource.data.users)
        && request.resource.data.createdAt == request.time
        && (!('typing' in request.resource.data) || request.resource.data.typing == {})
        // blockedBy (S19) é de propósito ausente desta lista: só a Cloud
        // Function onBlockCreated/onBlockDeleted (Admin SDK) pode escrevê-lo.
        && request.resource.data.keys().hasOnly(['users', 'createdAt', 'lastMessage', 'lastMessageAt', 'typing']);

      // Ninguém pode trocar os participantes depois de criado. Só lastMessage,
      // lastMessageAt e typing podem mudar (blockedBy também fica de fora daqui
      // pelo mesmo motivo acima) — e dentro de "typing", cada um só altera a
      // própria chave (não dá pra forjar "a outra pessoa está digitando").
      allow update: if isSignedIn() && request.auth.uid in resource.data.users
        && request.resource.data.users == resource.data.users
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['lastMessage', 'lastMessageAt', 'typing'])
        && (!('lastMessage' in request.resource.data) || request.resource.data.lastMessage is string)
        && (!('lastMessageAt' in request.resource.data) || request.resource.data.lastMessageAt is timestamp)
        && resource.data.get('typing', {}).diff(request.resource.data.get('typing', {}))
             .affectedKeys().hasOnly([request.auth.uid]);

      // Decisão: qualquer participante pode apagar o match a qualquer momento
      // (usado hoje só por undoSwipe(), mas também funciona como "desfazer
      // match"/unmatch geral). Débito técnico: mensagens da subcoleção ficam
      // órfãs (inacessíveis, mas não deletadas) — limpeza real exigiria uma
      // Cloud Function.
      allow delete: if isSignedIn() && request.auth.uid in resource.data.users;

      // ─────────────── matches/{matchId}/messages ───────────────
      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in getMatch(matchId).users;

        // blockedBy vazio/ausente (S19) é exigido no create: enquanto alguém
        // tiver o match bloqueado, ninguém — nem quem bloqueou, nem quem foi
        // bloqueado — consegue mandar mensagem, mesmo direto pela API.
        allow create: if isSignedIn()
          && matchAllowsPost(getMatch(matchId), request.auth.uid)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000
          && request.resource.data.createdAt == request.time
          && (!('imageUrl' in request.resource.data) || request.resource.data.imageUrl is string)
          && (!('location' in request.resource.data) ||
              (request.resource.data.location.latitude is number
               && request.resource.data.location.longitude is number))
          // mensagem precisa ter algum conteúdo: texto OU foto OU localização
          && (request.resource.data.text.size() > 0
              || 'imageUrl' in request.resource.data
              || 'location' in request.resource.data)
          && request.resource.data.keys().hasOnly(['text', 'senderId', 'createdAt', 'imageUrl', 'location']);

        // O app não tem função de editar/apagar mensagem hoje — deny by
        // default. Se um dia existir "apagar minha mensagem", trocar por:
        // allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ───────────────────────── blocks (S19) ─────────────────────────
    //
    // O client só cria/apaga o doc de bloqueio — nunca escreve users/{uid}.blockedUsers
    // diretamente (ver abaixo). Quem propaga o array pros dois lados e desfaz o
    // match é a Cloud Function onBlockCreated/onBlockDeleted (Admin SDK, ignora
    // estas regras) — ver functions/src/index.ts.
    //
    // Leitura restrita a quem bloqueou (ninguém lê "quem me bloqueou" por aqui —
    // essa informação só existe agregada, e sem direção, no array blockedUsers
    // de cada perfil, que já é público por causa do Descobrir/Swipe).
    match /blocks/{blockId} {
      allow read: if isSignedIn() && resource.data.blocker == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.blocker == request.auth.uid
        && request.resource.data.blocked is string
        && request.resource.data.blocked != request.auth.uid
        && blockId == request.resource.data.blocker + '_' + request.resource.data.blocked
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(['blocker', 'blocked', 'createdAt']);

      allow update: if false; // bloqueio é imutável — só se cria/apaga

      allow delete: if isSignedIn() && resource.data.blocker == request.auth.uid; // usado por unblockUser()
    }

    // ───────────────────────── reports (S19) ─────────────────────────
    //
    // Denúncia é só de ida: ninguém lê, edita ou apaga uma denúncia pelo client
    // (nem quem denunciou, nem quem foi denunciado) — revisão é manual, via
    // Console/Cloud Function futura.
    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.reportedId is string
        && request.resource.data.reportedId != request.auth.uid
        && request.resource.data.reason in
             ['spam', 'offensive_content', 'fake_profile', 'inappropriate_behavior', 'other']
        && request.resource.data.details is string && request.resource.data.details.size() <= 500
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(
             ['reporterId', 'reportedId', 'reason', 'details', 'createdAt']);

      allow read, update, delete: if false;
    }

    // ───────────────────────── verifications (S20) ─────────────────────────
    //
    // Pedido de verificação de perfil (selfie). Doc id == uid do usuário — 1
    // pedido por pessoa, reenviar sobrescreve o documento inteiro (por isso o
    // client precisa usar setDoc sem merge: um updateDoc parcial deixaria
    // reviewedAt/reviewedBy antigos no doc e o hasOnly() do dono abaixo
    // rejeitaria o reenvio).
    //
    // Uid do admin hardcoded de propósito (mesmo valor de ADMIN_UID em
    // src/config/admin.ts e do literal já usado na regra de create de
    // matches/{matchId} acima — Rules não importa constantes do app, então
    // os três precisam ficar em sincronia manual). A Cloud Function
    // onVerificationReviewed (Admin SDK, ignora estas regras) é quem
    // sincroniza users/{uid}.verified a partir da mudança de status aqui —
    // ver functions/src/index.ts.
    match /verifications/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // Dono cria/reenvia: só como 'pending', com selfieUrl e createdAt —
      // nunca consegue setar status já aprovado/rejeitado nem escrever
      // reviewedAt/reviewedBy (hasOnly bloqueia por padrão).
      allow create, update: if isOwner(uid)
        && request.resource.data.status == 'pending'
        && request.resource.data.selfieUrl is string
        && request.resource.data.selfieUrl.size() > 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(['status', 'selfieUrl', 'createdAt']);

      // Admin revisa: só pode mexer em status/reviewedAt/reviewedBy, e só pra
      // aprovar ou rejeitar — nunca reescreve selfieUrl/createdAt do usuário,
      // então não dá pra forjar uma aprovação por essa via nem pela do dono.
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'reviewedAt', 'reviewedBy'])
        && request.resource.data.status in ['approved', 'rejected']
        && request.resource.data.reviewedAt == request.time
        && request.resource.data.reviewedBy == request.auth.uid;

      allow delete: if false;
    }

    // ───────────────────────── deny by default ─────────────────────────
    // Qualquer collection não listada acima (inclusive erros de digitação no
    // nome de uma collection) é bloqueada por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
