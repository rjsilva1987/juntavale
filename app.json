{
  "expo": {
    "name": "JuntaVale",
    "slug": "juntavale",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#D84545"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.juntavale.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Para enviar fotos no chat.",
        "NSPhotoLibraryUsageDescription": "Para usar sua foto de perfil.",
        "NSLocationWhenInUseUsageDescription": "Para encontrar pessoas próximas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D84545"
      },
      "package": "com.juntavale.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-image-picker",
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FD3A69"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "177f208a-5816-40e5-9953-6511ba25a716"
      }
    },
    "owner": "rjsilva1987"
  }
}
